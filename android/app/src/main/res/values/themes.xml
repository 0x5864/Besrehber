<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

  <style name="Theme.BESRehber" parent="Theme.Material3.DayNight.NoActionBar">
    <item name="android:windowBackground">@color/bes_surface</item>
    <item name="android:statusBarColor">@color/bes_primary_dark</item>
    <item name="android:navigationBarColor">@color/bes_surface</item>
    <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>
    <item name="android:windowLightNavigationBar" tools:targetApi="27">true</item>
  </style>

  <style name="Theme.BESRehber.Starting" parent="Theme.SplashScreen">
    <item name="windowSplashScreenBackground">@color/bes_splash_background</item>
    <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_foreground</item>
    <item name="windowSplashScreenIconBackgroundColor">@color/bes_primary_soft</item>
    <item name="windowSplashScreenAnimationDuration">250</item>
    <item name="postSplashScreenTheme">@style/Theme.BESRehber</item>
  </style>

</resources>
